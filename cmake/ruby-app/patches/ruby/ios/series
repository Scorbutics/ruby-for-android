# Patch series for Ruby on iOS
# Patches are applied in order listed here

# sys/vnode.h is macOS-only (not in iOS SDK) but dir.c includes it
# unconditionally under #ifdef __APPLE__
fix-sys-vnode-ios.patch

# getentropy() exists on iOS but <sys/random.h> doesn't; provide
# the declaration directly so random.c can use it
fix-getentropy-ios.patch

# mkmf can't cross-compile test programs for iOS, so readline 8.x
# function detection fails; force-enable the modern names
fix-readline-extconf-ios.patch
